# ─────────────────────────────────────────────────────────────────────────────
# Backend environment
#
# Local: copy to apps/api/.env and adjust as needed.
# Production (Railway):
#   railway variables set KEY=VALUE --service api
# Never commit a populated .env file.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime
ENVIRONMENT=local                # local | test | production
APP_VERSION=0.1.0                # bump with releases; surfaced by /v1/health
GIT_SHA=local                    # in Railway, wire to ${{ RAILWAY_GIT_COMMIT_SHA }}

# Database — must use the asyncpg driver
# Local docker-compose maps Postgres to host port 5433.
# Railway: take ${{ Postgres.DATABASE_URL }} and replace `postgresql://` → `postgresql+asyncpg://`.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/ttm
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# JWT — generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# Rotate both secrets together; refresh tokens issued under the old secret will be rejected.
JWT_SECRET=change-me-to-48-bytes-base64
JWT_REFRESH_SECRET=change-me-to-different-48-bytes-base64
JWT_ACCESS_TTL_SECONDS=900       # 15 min
JWT_REFRESH_TTL_SECONDS=1209600  # 14 days
BCRYPT_ROUNDS=12

# CORS / cookies — comma-separated list of allowed origins (no trailing slashes).
# Production example: https://app.example.com
FRONTEND_URLS=http://localhost:5173

# Rate limiting (slowapi)
RATE_LIMIT_AUTH_PER_5MIN=10
RATE_LIMIT_USER_PER_MIN=120

# Observability
LOG_LEVEL=DEBUG                  # production: INFO
DOCS_ENABLED=true                # production: false (don't expose /docs publicly)
SENTRY_DSN=                      # set in production
REDIS_URL=                       # optional; reserved for future use

# ─────────────────────────────────────────────────────────────────────────────
# Frontend environment
#
# Local dev: VITE_API_BASE_URL must stay relative (`/v1`) so Vite proxies to
# :8000 on the same origin. This keeps the HttpOnly refresh cookie usable under
# SameSite=Strict.
#
# Production: point at the deployed API origin. The api and web services should
# share an eTLD+1 (e.g. both on *.example.com) so the refresh cookie flows.
# ─────────────────────────────────────────────────────────────────────────────

VITE_API_BASE_URL=/v1                 # prod: https://api.example.com/v1
VITE_ENVIRONMENT=local                # local | production
VITE_SENTRY_DSN=                      # set in production
VITE_COMMIT_SHA=local                 # Railway: ${{ RAILWAY_GIT_COMMIT_SHA }}
